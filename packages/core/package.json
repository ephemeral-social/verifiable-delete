{
  "name": "@ephemeral-social/verifiable-delete",
  "version": "0.1.0",
  "description": "Verifiable data deletion for the internet. Threshold crypto-shredding + W3C VC deletion receipts + public Merkle tree transparency log.",
  "license": "MIT",
  "author": "Ephemeral Social PBC <mansoor@ephemeralsocial.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ephemeral-social/verifiable-delete",
    "directory": "packages/core"
  },
  "keywords": [
    "deletion",
    "verifiable",
    "crypto-shredding",
    "privacy",
    "gdpr",
    "verifiable-credentials",
    "w3c",
    "encryption",
    "threshold-cryptography",
    "shamir",
    "merkle-tree",
    "transparency-log",
    "right-to-erasure"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto/index.js",
      "types": "./dist/crypto/index.d.ts"
    },
    "./threshold": {
      "import": "./dist/threshold/index.js",
      "types": "./dist/threshold/index.d.ts"
    },
    "./receipts": {
      "import": "./dist/receipts/index.js",
      "types": "./dist/receipts/index.d.ts"
    },
    "./log": {
      "import": "./dist/log/index.js",
      "types": "./dist/log/index.d.ts"
    },
    "./scan": {
      "import": "./dist/scan/index.js",
      "types": "./dist/scan/index.d.ts"
    },
    "./smt": {
      "import": "./dist/smt/index.js",
      "types": "./dist/smt/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.0",
    "@noble/hashes": "^1.7.0",
    "@zk-kit/sparse-merkle-tree": "^0.2.0",
    "shamir-secret-sharing": "^0.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
