{
  "name": "@ephemeral-social/verifiable-delete-cloudflare",
  "version": "0.1.0",
  "description": "Cloudflare Workers/Durable Objects adapter for Verifiable Delete.",
  "license": "MIT",
  "author": "Ephemeral Social PBC <mansoor@ephemeralsocial.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ephemeral-social/verifiable-delete",
    "directory": "packages/cloudflare"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
